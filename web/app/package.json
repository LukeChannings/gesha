{
  "name": "gesha-app",
  "version": "1.0.0",
  "description": "A tool for brewing espresso",
  "author": "Luke Channings <contact@lukechannings.com>",
  "main": "src/main.ts",
  "scripts": {
    "test": "jest",
    "format": "prettier --ignore-path ../../.gitignore . --write",
    "lint:format": "prettier --ignore-path ../../.gitignore . --check",
    "lint:typescript": "tsc",
    "lint:eslint": "eslint .",
    "lint": "run-p lint:*"
  },
  "keywords": [
    "Coffee",
    "PID",
    "Rancilio Silvia"
  ],
  "license": "MIT",
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.10.4",
    "@babel/preset-typescript": "^7.10.4",
    "@types/jest": "^26.0.10",
    "@typescript-eslint/eslint-plugin": "^3.9.0",
    "@typescript-eslint/parser": "^3.9.0",
    "eslint": "^7.7.0",
    "jest": "^26.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.0.5",
    "ts-jest": "^26.2.0",
    "typescript": "^3.9.7"
  },
  "babel": {
    "env": {
      "test": {
        "presets": [
          "@babel/preset-typescript"
        ],
        "plugins": [
          "@babel/plugin-transform-modules-commonjs"
        ]
      }
    }
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2020": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": 11,
      "sourceType": "module"
    },
    "plugins": [
      "@typescript-eslint"
    ]
  },
  "prettier": {
    "semi": false,
    "trailingComma": "all",
    "arrowParens": "avoid"
  },
  "dependencies": {
    "afix-dialog": "^1.1.0",
    "afix-list-item": "^1.0.5",
    "afix-range-slider": "^1.3.2"
  }
}
